body {
  font-family: Arial;
  background:#111;
  color:white;
  text-align:center;
  padding:20px;
}

input {
  padding:10px;
  margin:5px;
}

button {
  padding:10px 20px;
  margin:5px;
  background:#f64515;
  color:white;
  border:none;
}

.center-card {
  max-width:400px;
  margin:auto;
}

canvas {
  max-width:100%;
  margin:20px 0;
}

.risk-normal { color:lime; }
.risk-elevated { color:orange; }
.risk-high { color:red; }
